{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reading Progress Engine Category",
  "description": "Contract for one category file stored at data/categories/{slug}.json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "slug"
  ],
  "properties": {
    "name": {
      "$ref": "#/$defs/nonEmptyString",
      "description": "Display name of the category."
    },
    "slug": {
      "$ref": "#/$defs/slug",
      "description": "Category identifier and expected file name without .json."
    },
    "description": {
      "$ref": "#/$defs/nonEmptyString",
      "description": "Optional detailed category description."
    },
    "color": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$",
      "description": "Optional category color in #RRGGBB format."
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    }
  }
}
